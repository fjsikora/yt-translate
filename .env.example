# Universal Video Translator - Environment Variables
# Copy this file to .env and fill in your values

# ===================
# REQUIRED - AI APIs
# ===================
OPENAI_API_KEY=your-openai-api-key
REPLICATE_API_TOKEN=your-replicate-token

# ===================
# REQUIRED - Supabase
# ===================
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ===================
# REQUIRED - Payment provider
# ===================
# Get from: Payment provider Dashboard > Developers > API keys
PAYMENT_SECRET_KEY=sk_test_your-payment-provider-secret-key

# Get from: Payment provider Dashboard > Developers > Webhooks > Your endpoint > Signing secret
PAYMENT_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# URLs for Payment provider redirects (update for production)
PAYMENT_SUCCESS_URL=http://localhost:8000/success
PAYMENT_CANCEL_URL=http://localhost:8000/

# ===================
# REQUIRED - OAuth
# ===================
# Must match redirect URI in Google Cloud Console and Supabase Auth settings
OAUTH_REDIRECT_URL=http://localhost:8000/auth/callback

# ===================
# OPTIONAL - Pricing & Limits
# ===================
# Price per minute in cents (default: 50 = $0.50)
# PROCESSING_RATE=50

# Free preview duration in seconds (default: 60)
# PREVIEW_DURATION_SECONDS=60

# Rate limiting for previews (default: 5 per hour)
# PREVIEW_RATE_LIMIT=5
# PREVIEW_RATE_WINDOW=3600

# Maximum video duration in seconds (default: 600 = 10 min)
# MAX_VIDEO_DURATION=600

# Output directory for temporary files (default: /tmp/yt-translate)
# OUTPUT_DIR=/tmp/yt-translate
