# Universal Video Translator - Environment Variables
# Copy this file to .env and fill in your values

# ===================
# REQUIRED - AI APIs
# ===================
OPENAI_API_KEY=sk-your-openai-api-key
REPLICATE_API_TOKEN=r8_your-replicate-token

# ===================
# REQUIRED - Supabase
# ===================
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===================
# REQUIRED - Stripe
# ===================
# Get from: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Get from: Stripe Dashboard > Developers > Webhooks > Your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# URLs for Stripe redirects (update for production)
STRIPE_SUCCESS_URL=http://localhost:8000/success
STRIPE_CANCEL_URL=http://localhost:8000/

# ===================
# REQUIRED - OAuth
# ===================
# Must match redirect URI in Google Cloud Console and Supabase Auth settings
OAUTH_REDIRECT_URL=http://localhost:8000/auth/callback

HUGGINGFACE_TOKEN=

# ===================
# OPTIONAL - Pricing & Limits
# ===================
# Price per minute in cents (default: 50 = $0.50)
# PRICE_PER_MINUTE_CENTS=50

# Minimum purchase amount in cents (default: 299 = $2.99)
# MINIMUM_PURCHASE_CENTS=299

# Free preview duration in seconds (default: 60)
# PREVIEW_DURATION_SECONDS=60

# Rate limiting for previews (default: 5 per hour)
# PREVIEW_RATE_LIMIT=5
# PREVIEW_RATE_WINDOW=3600

# Maximum video duration in seconds (default: 600 = 10 min)
# MAX_VIDEO_DURATION=600

# Output directory for temporary files (default: /tmp/yt-translate)
# OUTPUT_DIR=/tmp/yt-translate

# ===================
# OPTIONAL - Proxy (for high-volume YouTube downloads)
# ===================
# Oxylabs proxy to bypass YouTube bot detection
# Sign up at: https://oxylabs.io/products/youtube-proxies
# Format: http://customer-USERNAME:PASSWORD@pr.oxylabs.io:7777
# OXYLABS_PROXY=http://customer-user:pass@pr.oxylabs.io:7777
