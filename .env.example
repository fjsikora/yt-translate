# yt-translate - Environment Variables
# Copy this file to .env and fill in your values

# ===================
# REQUIRED - Supabase
# ===================
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PROJECT_REF=your-project-ref-id
SUPABASE_SERVICE_KEY=your-service-role-key

# ===================
# REQUIRED - HuggingFace
# ===================
# Required for pyannote speaker diarization models
# Get from: https://huggingface.co/settings/tokens
# Accept model licenses at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=your-huggingface-token

# ===================
# OPTIONAL - Translation
# ===================
# OpenAI Whisper API (alternative to local Whisper)
OPENAI_API_KEY=your-openai-api-key

# Replicate (alternative TTS/LLM backend)
REPLICATE_API_TOKEN=your-replicate-token

# ===================
# OPTIONAL - Output
# ===================
# Output directory for temporary files (default: /tmp/yt-translate)
# OUTPUT_DIR=/tmp/yt-translate

# Maximum video duration in seconds (default: 600 = 10 min)
# MAX_VIDEO_DURATION=600

# ===================
# OPTIONAL - Proxy
# ===================
# Proxy to bypass YouTube bot detection (Oxylabs or similar)
# Format: http://customer-USERNAME:PASSWORD@pr.oxylabs.io:7777
# OXYLABS_PROXY=

# ===================
# OPTIONAL - YouTube Cookies
# ===================
# YouTube cookies in Netscape format (required if bot detection is blocking downloads)
# How to get: Install "Get cookies.txt LOCALLY" browser extension, sign into YouTube, export
# YOUTUBE_COOKIES=
