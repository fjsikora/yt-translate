# Unified Self-hosted GPU Dockerfile for Dubbing Studio
#
# This single image contains ALL AI models for the dubbing pipeline:
# - Whisper (large-v3) - Speech-to-text transcription
# - Demucs (htdemucs) - Audio source separation
# - pyannote.audio - Speaker diarization
# - Chatterbox TTS - Voice cloning text-to-speech
# - Qwen3-8B (GGUF) - Context-aware translation via llama.cpp
#
# All model weights are downloaded during build for faster cold starts.
#
# Build command:
#   docker build -f self-hosted/Dockerfile.unified -t dubbing-studio:latest .
#
# Estimated image size: ~25-30GB
# Required GPU: RTX 6000 Ada (48GB VRAM) or similar

FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04

# ============================================================================
# Environment Configuration
# ============================================================================
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Model cache directories
ENV HF_HOME=/root/.cache/huggingface
ENV TORCH_HOME=/root/.cache/torch
ENV WHISPER_CACHE=/root/.cache/whisper
ENV MODEL_PATH=/models/Qwen3-8B-Q4_K_M.gguf

# Build argument for gated model downloads (pyannote.audio)
# Pass with: docker build --build-arg HF_TOKEN=hf_xxx ...
# Note: This is NOT persisted in the final image ENV (only used during build)
ARG HF_TOKEN=""

# ============================================================================
# System Dependencies
# ============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    ffmpeg \
    git \
    wget \
    curl \
    libgomp1 \
    libsndfile1 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.11 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# ============================================================================
# Working Directory
# ============================================================================
WORKDIR /app

# ============================================================================
# PyTorch Installation (CUDA 12.4)
# ============================================================================
# Install PyTorch first to ensure correct CUDA version
# Using torch 2.5.1 to avoid PyTorch 2.6 weights_only=True breaking pyannote
RUN pip install --no-cache-dir \
    torch==2.5.1 \
    torchaudio==2.5.1 \
    --index-url https://download.pytorch.org/whl/cu124

# ============================================================================
# llama-cpp-python with CUDA support
# ============================================================================
# Install pre-built wheels with CUDA support (avoids compilation)
RUN pip install --no-cache-dir llama-cpp-python>=0.2.0 \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu124

# ============================================================================
# Requirements Installation
# ============================================================================
# Copy requirements and install
COPY self-hosted/requirements.unified.txt /app/requirements.unified.txt
RUN pip install --no-cache-dir -r /app/requirements.unified.txt

# Install chatterbox-tts with --no-deps to bypass torch==2.6.0 pin
# (chatterbox works fine with PyTorch 2.5.1, the strict pin is overly cautious)
RUN pip install --no-cache-dir --no-deps chatterbox-tts==0.1.6

# ============================================================================
# Model Downloads (Build Time)
# ============================================================================

# 1. Whisper large-v3 (~3GB) - using faster-whisper
# faster-whisper uses CTranslate2 format, downloads from HuggingFace Hub
RUN echo "Downloading Whisper large-v3 model (faster-whisper)..." && \
    python -c "from faster_whisper import WhisperModel; WhisperModel('large-v3', device='cpu', compute_type='int8')"

# 2. Demucs htdemucs (~500MB)
# Using demucs.pretrained instead of torch.hub.load for better reliability
RUN echo "Downloading Demucs htdemucs model..." && \
    python -c "from demucs.pretrained import get_model; get_model('htdemucs')"

# 3. Chatterbox Multilingual TTS models (~2GB)
# Downloaded from HuggingFace Hub on first use, but we pre-warm the cache
RUN echo "Downloading Chatterbox Multilingual TTS models..." && \
    python -c "from chatterbox.mtl_tts import ChatterboxMultilingualTTS; ChatterboxMultilingualTTS.from_pretrained(device='cpu')" || \
    echo "Chatterbox will download on first use (some models require runtime download)"

# 4. pyannote.audio models
# Note: Requires HF_TOKEN for gated model access
# Models will be downloaded at runtime if HF_TOKEN not provided at build time
RUN if [ -n "$HF_TOKEN" ]; then \
        echo "Downloading pyannote.audio models..." && \
        python -c "from pyannote.audio import Pipeline; Pipeline.from_pretrained('pyannote/speaker-diarization-3.1', use_auth_token='$HF_TOKEN')"; \
    else \
        echo "HF_TOKEN not provided - pyannote models will be downloaded at runtime"; \
    fi

# 5. Qwen3-8B GGUF model (~5GB)
# Using smaller 8B model for unified image (fits comfortably in 48GB VRAM)
RUN mkdir -p /models && \
    echo "Downloading Qwen3-8B-Q4_K_M model..." && \
    python -c "from huggingface_hub import hf_hub_download; \
        hf_hub_download(repo_id='Qwen/Qwen3-8B-GGUF', filename='Qwen3-8B-Q4_K_M.gguf', local_dir='/models')"

# ============================================================================
# Create cache directories
# ============================================================================
RUN mkdir -p /root/.cache/huggingface \
    /root/.cache/torch \
    /root/.cache/whisper \
    /models \
    /tmp/audio

# ============================================================================
# Copy Application Code
# ============================================================================
# Copy the entire package for imports
COPY yt_translate/ /app/yt_translate/
COPY self-hosted/ /app/self-hosted/

# ============================================================================
# Health Check
# ============================================================================
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# ============================================================================
# Expose Port
# ============================================================================
EXPOSE 8000

# ============================================================================
# Entrypoint
# ============================================================================
# Will be created in US-002: FastAPI server with health endpoint
CMD ["python", "-m", "uvicorn", "self-hosted.handler_unified:app", "--host", "0.0.0.0", "--port", "8000"]
